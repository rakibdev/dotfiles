pkgname=double-click-fix
pkgver=1.0
pkgrel=1
pkgdesc="R65 keyboard double-click fix"
arch=('x86_64')
license=('MIT')
source=('double-click-fix.zig' 'double-click-fix.service')
sha256sums=('SKIP' 'SKIP')

build() {
    zig build-exe double-click-fix.zig -OReleaseSmall -femit-bin=double-click-fix
}

package() {
    install -Dm755 double-click-fix "$pkgdir/usr/bin/double-click-fix"
    install -Dm644 double-click-fix.service "$pkgdir/usr/lib/systemd/system/double-click-fix.service"
}
