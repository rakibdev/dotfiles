<?xml version="1.0" encoding="UTF-8"?>
<actions>
<action>
	<icon>utilities-terminal</icon>
	<name>Open terminal</name>
	<submenu></submenu>
	<unique-id>1725197785250717-2</unique-id>
	<command>foot -D %f</command>
	<description></description>
	<range></range>
	<patterns>*</patterns>
	<directories/>
</action>
<action>
	<icon>video-x-generic</icon>
	<name>Open with ffplay</name>
	<submenu></submenu>
	<unique-id>1650439303972734-1</unique-id>
	<command>ffplay -loop 0 -loglevel quiet %f</command>
	<description></description>
	<range></range>
	<patterns>*</patterns>
	<audio-files/>
	<video-files/>
</action>
<action>
	<icon>7-zip</icon>
	<name>Extract</name>
	<submenu></submenu>
	<unique-id>1750234930186564-1</unique-id>
	<command>7z x -y %F</command>
	<description></description>
	<range></range>
	<patterns>*.rar;*.zip;*.7z;*.gz;*.tar,;*.xz</patterns>
	<other-files/>
</action>
<action>
	<icon>image-x-generic</icon>
	<name>Set as wallpaper</name>
	<unique-id>1752345678901234-5</unique-id>
	<command>ui /usr/lib/desktop/desktop.so wallpaper %f &amp;&amp; ~/Downloads/dotfiles/scripts/system-theme/theme.sh --source %f</command>
	<patterns>*.jpg;*.jpeg;*.png;*.webp</patterns>
	<image-files/>
</action>
</actions>
