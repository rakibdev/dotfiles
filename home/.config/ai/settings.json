{
  "model": ["kimi-k2-5"],
  "permissions": {
    "bash": {
      "*": "allow",
      "/\\brm\\s/": "ask",
      // not needed because terminal already ask password
      // "sudo *": "ask"
      "bun -e *": "ask",
      "git *": "ask",
      "git diff *": "allow",
      "git status *": "allow",
      "git show *": "allow",

      // todo: not working. e.g. `echo env`
      "*env*": "ask",

      // mongodb skill: allow only read operations
      "*db.*find*": "allow",
      "*db.*count*": "allow",
      "*db.*aggregate*": "allow",
      "*db.*": "ask"
    }
  },
  "agents": {
    "general": {
      "prompt": "~/.config/ai/general.md"
    },
    "coder": {
      "prompt": "~/.config/ai/coder.md",
      "description": "Use for implementating complex task"
    },
    "explore": {
      "model": "kimi-k2-5"
    }
  },
  "lsp": [
    {
      "command": ["tsgo", "--lsp", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx"],
      "diagDebounce": 500
    }
  ]
}
