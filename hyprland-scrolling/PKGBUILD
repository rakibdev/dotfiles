pkgname=hyprland-scrolling
pkgver=1.0
pkgrel=1
pkgdesc="Patches for Hyprland core scrolling layout"
arch=('x86_64')
depends=('hyprland')
makedepends=('hyprland' 'pkg-config' 'make' 'gcc')

build() {
    cd "$startdir"
    make
}

package() {
    cd "$startdir"
    install -Dm755 libhyprland-scrolling.so "$pkgdir/usr/lib/libhyprland-scrolling.so"
    make clean
}